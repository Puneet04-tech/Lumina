# Backend API - Production Environment
PORT=3500
NODE_ENV=production

# MongoDB Atlas Connection
# Get your connection string from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/lumina-db?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong secret key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secure_random_key_here_min_32_chars
JWT_EXPIRY=7d

# Groq AI API Configuration (Completely Free Tier)
# Sign up at https://console.groq.com and get your API key from the API Keys section
# FREE tier includes 30 requests per minute - perfect for shared projects
GROQ_API_TOKEN=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# CORS Configuration
CORS_ORIGIN=https://your-netlify-domain.netlify.app

# Frontend API URL
FRONTEND_URL=https://your-netlify-domain.netlify.app
